{
  "packageRules": [
    {
      "description": "Rook-Ceph image and chart",
      "matchDatasources": ["helm", "docker"],
      "matchPackagePatterns": ["^rook.ceph"],
      "groupName": "rook-ceph-suite",
      "group": {"commitMessageTopic": "{{{groupName}}} group"},
      "separateMinorPatch": true
    },
    {
      "matchDatasources": ["github-tags", "docker"],
      "matchPackagePatterns": ["rancher/system-upgrade-controller"],
      "groupName": "system-upgrade-controller-suite",
      "group": {"commitMessageTopic": "{{{groupName}}} group"},
      "separateMinorPatch": true
    },
    {
      "description": "Prometheus stack",
      "matchDatasources": ["github-tags", "helm", "docker"],
      "matchPackagePatterns": [".*kube-prometheus-stack.*"],
      "matchPackageNames": ["ghcr.io/prometheus-community/charts/prometheus-operator-crds"],
      "groupName": "kube-prometheus-stack",
      "group": {"commitMessageTopic": "{{{groupName}}} group"},
      "separateMinorPatch": true
    },
    {
      "description": "Kubernetes stack",
      "matchDatasources": ["docker", "github-releases"],
      "matchPackageNames": [
        "alpine/k8s",
        "kubernetes/kubernetes",
        "siderolabs/kubelet",
        "ghcr.io/siderolabs/kubelet"
      ],
      "groupName": "kubernetes",
      "group": {"commitMessageTopic": "{{{groupName}}} group"},
      "separateMinorPatch": true
    },
    {
      "description": "Talos stack",
      "matchDatasources": ["docker", "github-releases"],
      "matchPackageNames": [
        "budimanjojo/talhelper",
        "ghcr.io/mmalyska/talos-installer",
        "mmalyska/talos-images",
        "ghcr.io/siderolabs/installer"
      ],
      "groupName": "talos",
      "group": {"commitMessageTopic": "{{{groupName}}} group"},
      "separateMinorPatch": true
    },
    {
      "description": "Helm",
      "matchDatasources": ["github-releases"],
      "matchPackageNames": [
        "helm/helm"
      ],
      "groupName": "helm",
      "group": {"commitMessageTopic": "{{{groupName}}} group"},
      "separateMinorPatch": true
    },
    {
      "description": "Hermes agent — weekly digest updates only (frequent main builds cause excessive pod restarts)",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["nousresearch/hermes-agent"],
      "matchUpdateTypes": ["digest"],
      "automergeSchedule": ["before 5am on monday"]
    },
    {
      "description": "AzerothCore WoW server images",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/mmalyska/azerothcore-worldserver",
        "ghcr.io/mmalyska/azerothcore-authserver",
        "ghcr.io/mmalyska/azerothcore-db-import",
        "acore/ac-wotlk-client-data"
      ],
      "groupName": "azerothcore",
      "group": {"commitMessageTopic": "{{{groupName}}} group"},
      "automergeSchedule": ["before 5am on monday"]
    }
  ]
}
